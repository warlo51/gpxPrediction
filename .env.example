# ── Supabase ──
# Créer un projet sur https://supabase.com
# Récupérer l'URL et la clé anon dans Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ── Strava ──
# Créer une app sur https://www.strava.com/settings/api
# Mettre "localhost" comme domaine autorisé
# Callback URL : http://localhost:5173/strava/callback
VITE_STRAVA_CLIENT_ID=VOTRE_CLIENT_ID
VITE_STRAVA_CLIENT_SECRET=VOTRE_CLIENT_SECRET
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/strava/callback
